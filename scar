-- Pet ID Cache
local petIdCache = {}
local function getPetIdByName(name)
    if petIdCache[name] then return petIdCache[name] end
    for id, pet in pairs(Modules.InventoryDB.pets or {}) do
        if pet.name and pet.name:lower() == name:lower() then
            petIdCache[name] = id
            return id
        end
    end
    return nil
end

-- Make a pet legendary (rainbow)
local function makeLegendary(petId, petData)
    if legendaryRainbowEnabled then
        if Modules.InventoryDB and Modules.InventoryDB.pets and Modules.InventoryDB.pets[petId] then
            Modules.InventoryDB.pets[petId].rarity = "legendary"
            Modules.InventoryDB.pets[petId].displayed_rarity = "legendary"
            legendaryPets[petId] = true
        end
        if petData then
            petData.rarity = "legendary"
            petData.displayed_rarity = "legendary"
            petData.is_legendary = true
        end
        return true
    end
    return false
end

-- Spawn function
local function spawnPet()
    local petName = petNameBox.Text
    if petName == '' then
        Services.StarterGui:SetCore('SendNotification', {Title = 'Error', Text = 'Please enter a pet name!', Duration = 3})
        return
    end
    
    local actualName = petName
    if actualName:lower() == 'kangaroo' then actualName = 'Influencer Dragon' end
    
    local petId = getPetIdByName(actualName)
    if not petId then
        Services.StarterGui:SetCore('SendNotification', {Title = 'Error', Text = 'Pet not found: ' .. petName, Duration = 3})
        return
    end
    
    local props = {
        pet_trick_level = math.random(1, 5),
        mega_neon = activeFlags.M or nil,
        neon = (not activeFlags.M and activeFlags.N) or nil,
        rideable = activeFlags.R,
        flyable = activeFlags.F,
        age = math.random(1, 900000),
        ailments_completed = 0,
        rp_name = ''
    }
    if not activeFlags.M and not activeFlags.N then
        props.neon = false
        props.mega_neon = false
    end
    
    -- Create unique ID for the pet
    local uniqueId = Services.HttpService:GenerateGUID(false)
    
    -- Get inventory and add pet
    local inventory = Modules.ClientData.get('inventory')
    if not inventory then
        Services.StarterGui:SetCore('SendNotification', {Title = 'Error', Text = 'Could not access inventory', Duration = 3})
        return
    end
    
    if not inventory.pets then inventory.pets = {} end
    
    -- Get pet kind from ID
    local items = Fsys.load('KindDB')
    local item = items[petId]
    
    local newPet = {
        unique = uniqueId,
        category = 'pets',
        id = petId,
        kind = petId,
        newness_order = math.huge,
        properties = props
    }
    
    -- Override display name for Influencer Dragon
    if actualName == 'Influencer Dragon' then
        newPet.display_name = 'Influencer Dragon'
        newPet.name_override = 'Influencer Dragon'
    end
    
    -- Apply legendary rainbow if enabled
    local isLegendary = makeLegendary(petId, newPet)
    
    inventory.pets[uniqueId] = newPet
    
    -- Show notification
    if isLegendary then
        Services.StarterGui:SetCore('SendNotification', {
            Title = '⭐ LEGENDARY PET SPAWNED! ⭐',
            Text = actualName .. ' has been added with LEGENDARY rainbow rarity!',
            Duration = 5,
            Icon = 'rbxassetid://7742841814'
        })
        task.wait(0.1)
        Services.StarterGui:SetCore('SendNotification', {
            Title = '🌈 Rainbow Legendary Effect Active',
            Text = 'This pet displays with LEGENDARY rainbow colors!',
            Duration = 3
        })
    else
        Services.StarterGui:SetCore('SendNotification', {
            Title = 'Pet Spawned!',
            Text = actualName .. ' has been added to your inventory!',
            Duration = 4
        })
    end
    
    -- Clear input
    petNameBox.Text = ''
    
    -- Reset flags (keep legendary toggle state)
    for prefix, flag in pairs(activeFlags) do
        activeFlags[prefix] = false
        local btn = propButtons[prefix]
        if btn then
            btn.btn.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
            Services.TweenService:Create(btn.stroke, TweenInfo.new(0.2), {Color = prefixColors[prefix], Thickness = 2, Transparency = 0.5}):Play()
        end
    end
    updateInfoBox()
end

