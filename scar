local function getPetModel(kind)
    -- Check for custom model on Influencer Dragon
    local petData = Modules.InventoryDB.pets and Modules.InventoryDB.pets[kind]
    if petData and petData.name and (petData.name:lower() == "influencer dragon" or petData.name:lower() == "kangaroo") then
        local customModel = loadCustomModel()
        if customModel then return customModel end
    end
    if PetData.petModels[kind] then return PetData.petModels[kind]:Clone() end
    local success, streamed = pcall(function()
        local promise = PetData.downloader.promise_download_copy('Pets', kind)
        if promise then return promise:expect() end
        return nil
    end)
    if success and streamed then
        PetData.petModels[kind] = streamed
        return streamed:Clone()
    end
    return nil
end

