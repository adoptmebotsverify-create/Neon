-- ===== LEGENDARY RAINBOW SYSTEM =====
local rainbowEnabled = false
local rainbowConnection = nil
local rainbowLabels = {}  -- Track labels that have rainbow effect
local legendaryPets = {}  -- Track which pets have legendary rarity

-- Function to cycle rainbow colors
local function startRainbowEffect(label)
    if rainbowLabels[label] then return end
    rainbowLabels[label] = true
    
    local hue = 0
    local connection
    connection = Services.RunService.Heartbeat:Connect(function(dt)
        if not label or not label.Parent then
            connection:Disconnect()
            rainbowLabels[label] = nil
            return
        end
        if rainbowEnabled then
            hue = (hue + 0.8 * dt) % 1
            local color = Color3.fromHSV(hue, 1, 1)
            pcall(function()
                label.TextColor3 = color
            end)
        end
    end)
end

-- Function to stop rainbow effect
local function stopRainbowEffect(label)
    if rainbowLabels[label] then
        rainbowLabels[label] = nil
    end
end

